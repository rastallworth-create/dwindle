{
  "version": 2,
  "builds": [
    { "src": "api/api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/daily", "dest": "/api/api/daily.js" },
    { "src": "/api/image(.*)", "dest": "/api/api/image.js" },
    { "src": "/api/choices(.*)", "dest": "/api/api/choices.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
